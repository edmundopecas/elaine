# MODELO — copie para `.streamlit/secrets.toml` e preencha. O secrets.toml real
# NÃO vai pro GitHub (está no .gitignore). No Streamlit Cloud, cole este conteúdo
# em App → Settings → Secrets.

# Connection string do Supabase (Project Settings → Database → Connection string).
# Use o POOLER (porta 6543) pra aguentar várias sessões do Streamlit.
database_url = "postgresql://postgres.<ref>:<SENHA>@aws-0-<regiao>.pooler.supabase.com:6543/postgres"

# Usuários com acesso (senha como hash SHA-256 — gere com: python auth.py "senha")
[usuarios.filipe]
nome = "Filipe"
senha_hash = "COLE_O_HASH_AQUI"

[usuarios.diretoria]
nome = "Diretoria"
senha_hash = "COLE_O_HASH_AQUI"
